ifeq (Gcc,$(findstring Gcc,$(WM_COMPILER)))
    OMP_FLAGS = -DUSE_OMP -fopenmp
else
    OMP_FLAGS =
endif

ifeq (OpenFOAM,$(findstring OpenFOAM,$(WM_PROJECT)))
    ifeq (v,$(WM_PROJECT_VERSION:v%=v))
        VER := $(shell expr `echo $(WM_PROJECT_VERSION)` \>= v1706)
        ifeq ($(VER), 1)
            CFMESH_MACROS = -DOpenCFDSpecific -DOFVersionPost5
            LIBS = -lmeshTools -lsurfMesh
        else
            CFMESH_MACROS = -DOpenCFDSpecific
            LIBS = -lmeshTools -ltriSurface -ledgeMesh
        endif
    else
        VER := $(shell expr `echo $(WM_PROJECT_VERSION)` \>= 5.0)
        ifeq ($(VER),1)
            CFMESH_MACROS = -DOFVersionPost5
            LIBS = -ltriSurface -lmeshTools
        else
            CFMESH_MACROS =
            LIBS = -ltriSurface -ledgeMesh -lmeshTools
        endif
    endif
    ifeq (Int,$(findstring Int,$(WM_LABEL_OPTION)))
        CFMESH_MACROS := $(CFMESH_MACROS) -DNoSizeType
    else
        CFMESH_MACROS := $(CFMESH_MACROS)
    endif
endif

ifeq ($(WM_PROJECT), foam)
    VER := $(shell expr `echo $(WM_PROJECT_VERSION)` \>= 3.2)
    ifeq ($(VER), 1)
        CFMESH_MACROS = -DExtendSpecific -std=c++11
        LIBS = -lmeshTools -ledgeMesh
    else
        CFMESH_MACROS =
    endif
endif

EXE_INC = \
    $(OMP_FLAGS) $(CFMESH_MACROS) \
    -I$(LIB_SRC)/triSurface/lnInclude \
    -I$(LIB_SRC)/surfMesh/lnInclude \
    -I$(LIB_SRC)/edgeMesh/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude

LIB_LIBS = $(LIBS)
