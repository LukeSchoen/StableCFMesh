ifeq (Gcc,$(findstring Gcc,$(WM_COMPILER)))
    OMP_FLAGS = -DUSE_OMP -fopenmp
else
    OMP_FLAGS =
endif

ifeq (OpenFOAM,$(findstring OpenFOAM,$(WM_PROJECT)))
    MAJ_VER := $(WM_PROJECT_VERSION:v%=%)
    MAJ_VER := $(subst ., ,$(MAJ_VER))
    MAJ_VER := $(word 1,$(MAJ_VER))

    ifeq ($(shell expr $(MAJ_VER) \>= 1000), 1)
        ifeq ($(shell expr $(MAJ_VER) \>= 1706), 1)
            CFMESH_MACROS = -DOpenCFDSpecific
            LIBS = -lmeshTools -lsurfMesh
        else
            CFMESH_MACROS = -DOpenCFDSpecific
            LIBS = -lmeshTools -ltriSurface -ledgeMesh
        endif
    else
        ifeq ($(shell expr $(MAJ_VER) \>= 5), 1)
            CFMESH_MACROS =
            LIBS = -ltriSurface -lmeshTools
        else
            CFMESH_MACROS =
            LIBS = -ltriSurface -ledgeMesh -lmeshTools
        endif
    endif

    ifeq (OpenFOAM-dev,$(findstring OpenFOAM-dev,$(WM_PROJECT_DIR)))
        CFMESH_LIBS = -lmeshTools -ltriSurface
    endif    
    ifeq (OpenFOAM-plus,$(findstring OPENFOAM-plus,$(WM_PROJECT_DIR)))
            CFMESH_LIBS = -lmeshTools -lsurfMesh
    endif

    ifeq (Int,$(findstring Int,$(WM_LABEL_OPTION)))
        CFMESH_MACROS := $(CFMESH_MACROS) -DNoSizeType
    else
        CFMESH_MACROS := $(CFMESH_MACROS)
    endif
endif

ifeq ($(WM_PROJECT), foam)
    VER := $(shell expr $(WM_PROJECT_VERSION) \>= 3.2)
    ifeq ($(VER), 1)
        CFMESH_MACROS = -DExtendSpecific -std=c++11
        LIBS = -lmeshTools -ledgeMesh
    else
        CFMESH_MACROS =
    endif
endif

ifdef BLUECFDPATH
    BLUECFD = -DBLUECFD
endif

EXE_INC = \
    $(OMP_FLAGS) $(CFMESH_MACROS) $(BLUECFD) \
    -I$(LIB_SRC)/triSurface/lnInclude \
    -I$(LIB_SRC)/surfMesh/lnInclude \
    -I$(LIB_SRC)/edgeMesh/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude

LIB_LIBS = $(LIBS)
